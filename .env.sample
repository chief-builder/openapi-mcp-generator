# Sample environment file for testing
# Copy this to .env and add your API keys

# Stripe API key (test/sandbox key only!)
STRIPE_API_KEY=sk_test_your_test_key_here

# PayPal API credentials (sandbox only!)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# PayPal test server configuration
SERVER_PORT=9003
SERVER_DIR=./paypal-payment-server