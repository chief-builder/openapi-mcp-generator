{
  "name": "openapi-mcp-generator",
  "version": "0.1.0",
  "description": "Generate Model Context Protocol (MCP) servers from OpenAPI specifications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openapi-mcp-generator": "dist/cli/index.js"
  },
  "scripts": {
    "build": "npx tsc",
    "start": "ts-node src/cli/index.ts",
    "dev": "ts-node src/cli/index.ts",
    "test:stripe": "ts-node src/test/stripe.test.ts",
    "test:functional": "ts-node src/test/functional/test-generated-server.ts",
    "test:simple": "ts-node src/test/simple-prompt-test.ts",
    "test:prompts": "ts-node src/test/functional/prompt-functional-test.ts",
    "generate": "ts-node src/cli/index.ts generate",
    "list-providers": "ts-node src/cli/index.ts list-providers",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "openapi",
    "mcp",
    "model-context-protocol",
    "generator",
    "stripe",
    "ai",
    "claude",
    "ai-assistant"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "node-fetch": "^2.7.0",
    "openapi-types": "^12.1.3",
    "prettier": "^3.1.0",
    "stripe": "^12.16.0",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.9.4",
    "@types/node-fetch": "^2.6.12",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/openapi-mcp-generator.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/openapi-mcp-generator/issues"
  },
  "homepage": "https://github.com/yourusername/openapi-mcp-generator#readme"
}
