{
  "name": "openapi-mcp-generator",
  "version": "0.2.0",
  "description": "Generate Model Context Protocol (MCP) servers from OpenAPI specifications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openapi-mcp-generator": "dist/cli/index.js"
  },
  "scripts": {
    "build": "npx tsc",
    "start": "ts-node src/cli/index.ts",
    "dev": "ts-node src/cli/index.ts",
    "test:integration": "jest src/test/integration --forceExit",
    "generate": "ts-node src/cli/index.ts generate",
    "list-providers": "ts-node src/cli/index.ts list-providers",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "test:e2e": "node src/test/e2e/runtime-smoke.mjs",
    "test:red-team": "node src/test/e2e/red-team-weekend.mjs",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "openapi",
    "mcp",
    "model-context-protocol",
    "generator",
    "stripe",
    "ai",
    "claude",
    "ai-assistant"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.5.0",
    "fs-extra": "^11.2.0",
    "openapi-types": "^12.1.3",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "jose": "^6.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.63.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/openapi-mcp-generator.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/openapi-mcp-generator/issues"
  },
  "homepage": "https://github.com/yourusername/openapi-mcp-generator#readme"
}
