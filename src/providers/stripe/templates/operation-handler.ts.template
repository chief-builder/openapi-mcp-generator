  /**
   * ${description}
   */
  private async ${methodName}(params: any, authContext?: IMCPAuthContext): Promise<any> {
   const stripe = this.getStripeClient(authContext);
   
   try {
 ${operationCode}
   } catch (error) {
     // Log the error for server-side debugging
     console.error(`[StripeServer] Error in ${methodName}:`, error);
     
     // Return an error result that follows the MCP tool error format
     // This will be wrapped in a successful JSON-RPC response
     // but marked as an error for the LLM to interpret
     return {
       isError: true,
       content: [
         {
           type: 'text',
           text: `Error: ${error.message}`
         }
       ],
       error: {
         code: error.type || 'stripe_error',
         message: error.message,
         param: error.param,
         declineCode: error.decline_code
       }
     };
   }
 }